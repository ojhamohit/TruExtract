# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=sample_key

# Optional: Set to 'false' to disable LLM verification (falls back to heuristic-only)
ENABLE_LLM_VERIFICATION=true

# Optional: Set to 'false' to disable vision for images/PDFs (text-only mode)
ENABLE_VISION=true

# Optional: Set to 'false' to disable few-shot learning (faster but less accurate)
ENABLE_FEW_SHOT_LEARNING=true

# Server configuration
PORT=3000
